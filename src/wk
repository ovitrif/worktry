# Create .worktreeinclude file with example patterns
create_worktreeinclude() {
  cat > .worktreeinclude << 'EOF'
# Files to copy to new worktrees/clones
# Uses gitignore-style patterns
# Files must ALSO be in .gitignore to be copied

# Environment files
.env
.env.local
.env.*

# Claude local settings
**/.claude/settings.local.json

# IDE settings
.idea/
# .vscode/

# Local properties (uncomment as needed)
# local.properties
# keystore.properties
EOF
}

# Create .worktree-setup.sh script
create_setup_script() {
  cat > .worktree-setup.sh << 'SETUP_EOF'
#!/bin/bash
# Worktry setup script - runs in new worktree/clone

# Create Claude Code settings
mkdir -p .claude
cat > .claude/settings.local.json << 'JSON_EOF'
{
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "WebFetch",
      "mcp__ide__getDiagnostics",
      "WebSearch",
      "mcp__github__pull_request_read",
      "mcp__github__search_pull_requests",
      "mcp__github__list_pull_requests"
    ],
    "deny": [],
    "ask": [
      "Bash(rm -rf:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)"
    ]
  }
}
JSON_EOF

# Copy files matching BOTH .worktreeinclude AND .gitignore
copy_worktree_files() {
  local source_dir="$1"
  local include_file="$source_dir/.worktreeinclude"

  [ ! -f "$include_file" ] && return 0

  # Get all ignored files in source directory
  local ignored_files
  ignored_files=$(cd "$source_dir" && git ls-files --others --ignored --exclude-standard 2>/dev/null)

  [ -z "$ignored_files" ] && return 0

  # Read patterns from .worktreeinclude
  while IFS= read -r pattern || [ -n "$pattern" ]; do
    # Skip comments and empty lines
    [[ "$pattern" =~ ^[[:space:]]*# ]] && continue
    [[ -z "${pattern// }" ]] && continue
    pattern=$(echo "$pattern" | xargs)  # Trim whitespace

    # Match pattern against ignored files
    echo "$ignored_files" | while read -r file; do
      [ -z "$file" ] && continue

      # Pattern matching: handle glob patterns
      local matched=false

      # Direct match
      if [[ "$file" == $pattern ]]; then
        matched=true
      # Directory pattern (pattern/)
      elif [[ "$pattern" == */ ]] && [[ "$file" == ${pattern}* ]]; then
        matched=true
      # Wildcard pattern (*.ext, .env.*)
      elif [[ "$file" == $pattern ]]; then
        matched=true
      # Double-star pattern (**/file)
      elif [[ "$pattern" == \*\*/* ]]; then
        local suffix="${pattern#\*\*/}"
        if [[ "$file" == *"$suffix" ]] || [[ "$file" == "$suffix" ]]; then
          matched=true
        fi
      fi

      if [ "$matched" = true ]; then
        local src="$source_dir/$file"
        if [ -e "$src" ]; then
          mkdir -p "$(dirname "$file")"
          cp -r "$src" "$file"
          echo "  Copied: $file"
        fi
      fi
    done
  done < "$include_file"
}

copy_worktree_files "$ROOT_WORKTREE_PATH"
SETUP_EOF
  chmod +x .worktree-setup.sh
}

# Initialize for worktree mode
init_worktree_mode() {
  if [ -f ".worktreeinclude" ]; then
    echo "Error: .worktreeinclude already exists."
    echo "Remove it first or edit manually."
    exit 1
  fi

  create_worktreeinclude
  create_setup_script

  echo "Created:"
  echo "  .worktreeinclude      # Add patterns for files to copy"
  echo "  .worktree-setup.sh    # Setup script"
  echo ""
  echo "Next steps:"
  echo "  1. Edit .worktreeinclude with files to copy"
  echo "  2. wk new <branch>         # Create worktree with setup"
}

# Initialize for clone mode
init_clone_mode() {
  if [ -f ".worktreeinclude" ]; then
    echo "Error: .worktreeinclude already exists."
    echo "Remove it first or edit manually."
    exit 1
  fi

  create_worktreeinclude
  create_setup_script

  echo "Clone mode initialized!"
  echo ""
  echo "Created:"
  echo "  .worktreeinclude      # Add patterns for files to copy"
  echo "  .worktree-setup.sh    # Setup script"
  echo ""
  echo "Usage:"
  echo "  gh repo clone user/repo repo-2    # Clone"
  echo "  wk setup ../repo-2                # Apply setup"
}

create_worktree() {
  local name=""
  local base_branch="HEAD"
  
  # Parse arguments
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --base|-b)
        base_branch="$2"
        shift 2
        ;;
      *)
        if [ -z "$name" ]; then
          name="$1"
        else
          echo "Error: Unknown argument '$1'" >&2
          echo "Usage: wk new <NAME> [--base|-b BASE_BRANCH]" >&2
          exit 1
        fi
        shift
        ;;
    esac
  done

  if [ -z "$name" ]; then
    echo "Error: Name argument is required."
    echo "Usage: wk new <NAME> [--base|-b BASE_BRANCH]"
    exit 1
  fi

  TARGET_PATH=".claude/worktrees/${name}"

  echo "Creating worktree '$name' at '$TARGET_PATH' from '$base_branch'..."
  git worktree add "$TARGET_PATH" -b "$name" "$base_branch"

  # Run setup if .worktree-setup.sh exists
  local source_dir="$PWD"
  if [ -f ".worktree-setup.sh" ]; then
    echo "Running setup..."
    (cd "$TARGET_PATH" && ROOT_WORKTREE_PATH="$source_dir" bash "$source_dir/.worktree-setup.sh")
  fi
}

# Navigate to a worktree by branch name
go_to_worktree() {
  local name="$1"
  if [ -z "$name" ]; then
    echo "Error: Branch name required." >&2
    echo "Usage: wk go <branch-name>" >&2
    exit 1
  fi

  # Find worktree path by branch name
  local path=$(git worktree list --porcelain 2>/dev/null | awk -v branch="$name" '
    /^worktree / { wt = substr($0, 10) }
    /^branch / { if ($0 ~ branch "$") print wt }
  ')

  if [ -z "$path" ]; then
    echo "Error: No worktree found for branch '$name'" >&2
    exit 1
  fi

  # Output path for shell function to cd
  echo "$path"
}

# Navigate back to main worktree
go_back() {
  # Main worktree is the one without "branch" being a linked worktree
  # It's typically the first one listed, or we find the one that's not bare
  local main_path=$(git worktree list --porcelain 2>/dev/null | awk '
    /^worktree / { wt = substr($0, 10) }
    /^bare$/ { next }
    /^HEAD / { if (wt) { print wt; exit } }
  ')

  if [ -z "$main_path" ]; then
    # Fallback: first worktree
    main_path=$(git worktree list 2>/dev/null | head -1 | awk '{print $1}')
  fi

  if [ -z "$main_path" ]; then
    echo "Error: Could not find main worktree" >&2
    exit 1
  fi

  echo "$main_path"
}

# Check if in clone mode (no linked worktrees, but sibling clones exist)
is_clone_mode() {
  local wt_count=$(git worktree list 2>/dev/null | wc -l | tr -d ' ')
  # Clone mode if only 1 worktree (main) exists
  [[ "$wt_count" -le 1 ]]
}

# List sibling clone directories (same repo name prefix)
list_clones() {
  local current_dir=$(pwd)
  local parent_dir=$(dirname "$current_dir")
  local base_name=$(basename "$current_dir")
  
  # Remove any suffix like -2, -3, .feature to get base name
  base_name=$(echo "$base_name" | sed -E 's/[-.]?[0-9]+$//' | sed -E 's/\.[^.]+$//')
  
  # Find all directories matching base_name* that are git repos, sorted
  local clones=()
  while IFS= read -r dir; do
    if [[ -d "$dir/.git" || -f "$dir/.git" ]]; then
      clones+=("$dir")
    fi
  done < <(find "$parent_dir" -maxdepth 1 -type d -name "${base_name}*" 2>/dev/null | sort)
  
  printf '%s\n' "${clones[@]}"
}

# Navigate to worktree/clone by index (0 = main, 1-9 = others)
go_to_index() {
  local index="$1"
  
  if is_clone_mode; then
    # Clone mode: navigate by clone index
    local clones=()
    while IFS= read -r line; do
      [[ -n "$line" ]] && clones+=("$line")
    done < <(list_clones)
    
    if [[ $index -ge ${#clones[@]} ]]; then
      echo "Error: No clone at index $index" >&2
      echo "" >&2
      echo "Available clones:" >&2
      local i=0
      for clone in "${clones[@]}"; do
        echo "$i  $clone" >&2
        ((i++))
      done
      exit 1
    fi
    
    echo "${clones[$index]}"
  else
    # Worktree mode
    if [ "$index" = "0" ]; then
      go_back
      return
    fi
    
    local path=$(git worktree list 2>/dev/null | sed -n "$((index + 1))p" | awk '{print $1}')
    
    if [ -z "$path" ]; then
      echo "Error: No worktree at index $index" >&2
      echo "" >&2
      echo "Available worktrees:" >&2
      local i=0
      git worktree list 2>/dev/null | while IFS= read -r line; do
        echo "$i  $line" >&2
        ((i++))
      done
      echo "" >&2
      local total=$(git worktree list 2>/dev/null | wc -l | tr -d ' ')
      echo "wk new feature         # Create worktree with setup" >&2
      echo "It will be available as: wk $total" >&2
      exit 1
    fi
    
    echo "$path"
  fi
}

# List worktrees or clones with index prefix, type, and current marker
list_indexed() {
  local current_dir
  current_dir=$(pwd -P)

  if is_clone_mode; then
    local i=0
    while IFS= read -r clone; do
      if [[ -n "$clone" ]]; then
        local resolved
        resolved=$(cd "$clone" 2>/dev/null && pwd -P)
        if [[ "$resolved" == "$current_dir" ]]; then
          echo "$i  $clone  [clone] *"
        else
          echo "$i  $clone  [clone]"
        fi
        ((i++))
      fi
    done < <(list_clones)
  else
    local i=0
    git worktree list 2>/dev/null | while IFS= read -r line; do
      local wt_path
      wt_path=$(echo "$line" | awk '{print $1}')
      local resolved
      resolved=$(cd "$wt_path" 2>/dev/null && pwd -P)
      if [[ "$resolved" == "$current_dir" ]]; then
        echo "$i  $line  [worktree] *"
      else
        echo "$i  $line  [worktree]"
      fi
      ((i++))
    done
  fi
}

# Apply worktry setup to an existing clone directory
setup_clone() {
  local target_dir="$1"
  
  if [ -z "$target_dir" ]; then
    echo "Error: Directory argument required." >&2
    echo "Usage: wk setup <directory>" >&2
    exit 1
  fi
  
  # Resolve to absolute path
  if [[ ! "$target_dir" = /* ]]; then
    target_dir="$(pwd)/$target_dir"
  fi
  
  if [ ! -d "$target_dir" ]; then
    echo "Error: Directory '$target_dir' does not exist." >&2
    exit 1
  fi
  
  if [ ! -d "$target_dir/.git" ] && [ ! -f "$target_dir/.git" ]; then
    echo "Error: '$target_dir' is not a git repository." >&2
    exit 1
  fi
  
  local source_dir=$(pwd)
  
  if [ ! -f "$source_dir/.worktree-setup.sh" ]; then
    echo "Error: No .worktree-setup.sh in current directory." >&2
    echo "Run 'wk init' first." >&2
    exit 1
  fi
  
  echo "Applying wk setup to $target_dir..."
  (cd "$target_dir" && ROOT_WORKTREE_PATH="$source_dir" bash "$source_dir/.worktree-setup.sh")
  echo "‚úď Setup complete"
}

# Edit .worktreeinclude config file
edit_config() {
  local configfile=".worktreeinclude"

  if [ ! -f "$configfile" ]; then
    echo "Error: $configfile not found." >&2
    echo "Run 'wk init' first." >&2
    exit 1
  fi

  local editor="${EDITOR:-${VISUAL:-}}"

  if [ -n "$editor" ]; then
    $editor "$configfile"
  else
    echo "No default text editor configured."
    echo ""
    echo "To set one, add to your shell config (~/.zshrc or ~/.bashrc):"
    echo "  export EDITOR=nano      # or vim, subl, code, etc."
    echo ""
    read -p "Open with VSCode instead? [y/N] " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
      code "$configfile"
    fi
  fi
}

case "$1" in
  init|i)
    shift
    case "$1" in
      --clone|-c)
        init_clone_mode
        ;;
      "")
        init_worktree_mode
        ;;
      *)
        echo "Error: Unknown option '$1'" >&2
        echo "Usage: wk init [--clone]" >&2
        exit 1
        ;;
    esac
    ;;
  go)
    go_to_worktree "$2"
    ;;
  back|b)
    go_back
    ;;
  list|ls|l)
    list_indexed
    ;;
  config|c)
    edit_config
    ;;
  setup|s)
    setup_clone "$2"
    ;;
  new|n)
    shift
    create_worktree "$@"
    ;;
  -h|--help|"")
    show_help
    ;;
  [0-9])
    go_to_index "$1"
    ;;
  *)
    echo "Error: Unknown command '$1'"
    echo ""
    show_help
    exit 1
    ;;
esac
