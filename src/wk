warn_if_navigation_wrapper_inactive() {
  if [[ -n "${WK_SHELL_WRAPPER:-}" || ! -t 1 ]]; then
    return
  fi

  local source_hint="source your shell config"
  if [[ "${SHELL:-}" == */zsh ]]; then
    source_hint="source ~/.zshrc"
  elif [[ "${SHELL:-}" == */bash ]]; then
    source_hint="source ~/.bashrc"
  fi

  echo "Note: wk can only print this path because the shell navigation wrapper is not active in this terminal." >&2
  echo "Run '$source_hint' or open a new terminal so wk can cd for navigation commands." >&2
}

print_navigation_target() {
  warn_if_navigation_wrapper_inactive
  echo "$1"
}

# Create .worktreeinclude file with example patterns
create_worktreeinclude() {
  local dir="${1:-.}"

  cat > "$dir/.worktreeinclude" << 'EOF'
# Files to copy to new worktrees/clones
# Uses gitignore-style patterns
# Files must ALSO be in .gitignore to be copied

# Environment files
.env
.env.local
.env.*

# Claude local settings
**/.claude/settings.local.json

# IDE settings
.idea/
# .vscode/

# Android/Firebase config
google-services.json

# Local properties (uncomment as needed)
# local.properties
# keystore.properties
EOF
}

ensure_worktreeinclude_defaults() {
  local dir="${1:-.}"
  local include_file="$dir/.worktreeinclude"

  if ! awk '
    /^[[:space:]]*($|#)/ { next }
    /(^|[[:space:]])google-services[.]json[[:space:]]*$/ { found = 1 }
    END { exit found ? 0 : 1 }
  ' "$include_file" 2>/dev/null; then
    {
      echo ""
      echo "# Android/Firebase config"
      echo "google-services.json"
    } >> "$include_file"
    echo "Updated .worktreeinclude defaults"
  fi
}

# Auto-create .worktreeinclude if missing
ensure_worktreeinclude() {
  local dir="${1:-.}"

  if [ ! -f "$dir/.worktreeinclude" ]; then
    create_worktreeinclude "$dir"
    echo "Created .worktreeinclude template"
  else
    ensure_worktreeinclude_defaults "$dir"
  fi
}

resolve_repo_dir() {
  local dir="${1:-$PWD}"
  local repo_root

  if [[ "$dir" != /* ]]; then
    dir="$PWD/$dir"
  fi

  repo_root=$(git -C "$dir" rev-parse --show-toplevel 2>/dev/null)
  if [ -z "$repo_root" ]; then
    echo "Error: '$dir' is not inside a git repository." >&2
    exit 1
  fi

  cd "$repo_root" && pwd
}

get_default_branch() {
  local repo_dir="$1"
  local branch=""

  branch=$(git -C "$repo_dir" symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null)
  if [ -n "$branch" ]; then
    echo "${branch#origin/}"
    return
  fi

  branch=$(git -C "$repo_dir" remote show origin -n 2>/dev/null | awk -F': ' '/HEAD branch/ {print $2; exit}')
  if [ -n "$branch" ] && [ "$branch" != "(unknown)" ] && [ "$branch" != "(not queried)" ]; then
    echo "$branch"
    return
  fi

  branch=$(git -C "$repo_dir" config --get init.defaultBranch 2>/dev/null)
  if [ -n "$branch" ] && git -C "$repo_dir" show-ref --verify --quiet "refs/heads/$branch"; then
    echo "$branch"
    return
  fi

  if git -C "$repo_dir" show-ref --verify --quiet refs/heads/main; then
    echo "main"
    return
  fi

  if git -C "$repo_dir" show-ref --verify --quiet refs/heads/master; then
    echo "master"
    return
  fi

  branch=$(git -C "$repo_dir" symbolic-ref --quiet --short HEAD 2>/dev/null)
  if [ -n "$branch" ]; then
    echo "$branch"
  else
    echo "HEAD"
  fi
}

prompt_value() {
  local label="$1"
  local default_value="$2"
  local reply=""
  local prompt="$label"

  if [ -n "$default_value" ]; then
    prompt="${label}ENTER (default: ${default_value}) or type to customize: "
  fi

  if [ -t 0 ]; then
    reply=$(read_interactive_line "$prompt") || exit $?
  else
    read -r reply
  fi

  [ -z "$reply" ] && reply="$default_value"
  echo "$reply"
}

cancel_interactive() {
  echo "" >&2
  echo "Canceled." >&2
  exit 130
}

read_interactive_line() {
  local prompt="$1"
  local reply=""
  local key=""
  local next=""
  local esc_pending=false

  printf "%s" "$prompt" >&2

  while true; do
    if ! IFS= read -rsn1 key; then
      cancel_interactive
    fi

    case "$key" in
      "")
        printf "\n" >&2
        echo "$reply"
        return
        ;;
      $'\e')
        if IFS= read -rsn1 -t 1 next; then
          if [ "$next" = $'\e' ]; then
            cancel_interactive
          fi

          if [[ "$next" == "[" || "$next" == "O" ]]; then
            IFS= read -rsn1 -t 1 key || true
            esc_pending=false
            continue
          fi
        fi

        if [ "$esc_pending" = true ]; then
          cancel_interactive
        fi

        esc_pending=true
        printf "\nPress Esc again to cancel, or keep typing.\n%s%s" "$prompt" "$reply" >&2
        ;;
      $'\177'|$'\b')
        esc_pending=false
        if [ -n "$reply" ]; then
          reply="${reply%?}"
          printf "\b \b" >&2
        fi
        ;;
      *)
        esc_pending=false
        if [[ "$key" =~ [[:print:]] ]]; then
          reply="${reply}${key}"
          printf "%s" "$key" >&2
        fi
        ;;
    esac
  done
}

auto_clone_name() {
  local source_dir="$1"
  local base_name
  local parent_dir
  local i=2

  base_name=$(basename "$source_dir")
  base_name=$(echo "$base_name" | sed -E 's/[-.]?[0-9]+$//' | sed -E 's/\.[^.]+$//')
  parent_dir=$(dirname "$source_dir")

  while [ -d "$parent_dir/${base_name}-${i}" ]; do
    ((i++))
  done

  echo "${base_name}-${i}"
}

sanitize_workspace_name() {
  local value="$1"

  value=$(printf "%s" "$value" | sed -E 's#[/[:space:]]+#-#g; s#[^A-Za-z0-9._-]+#-#g; s#^-+##; s#-+$##; s#-+#-#g')
  if [ -n "$value" ]; then
    echo "$value"
  else
    echo "workspace"
  fi
}

get_current_branch() {
  local repo_dir="$1"
  local branch=""

  branch=$(git -C "$repo_dir" symbolic-ref --quiet --short HEAD 2>/dev/null)
  if [ -n "$branch" ]; then
    echo "$branch"
  else
    get_default_branch "$repo_dir"
  fi
}

auto_worktree_name() {
  local source_dir="$1"
  local branch_hint="$2"
  local base_name
  local candidate
  local i=2

  base_name=$(sanitize_workspace_name "$branch_hint")
  if [ "$base_name" = "HEAD" ]; then
    base_name="worktree"
  fi

  candidate="$base_name"
  while [ -e "$source_dir/.claude/worktrees/$candidate" ] || git -C "$source_dir" show-ref --verify --quiet "refs/heads/$candidate"; do
    candidate="${base_name}-${i}"
    ((i++))
  done

  echo "$candidate"
}

prompt_menu_choice() {
  local default_choice="$1"
  local max_choice="$2"
  local reply=""
  local current="$default_choice"
  local key=""
  local next=""
  local esc_pending=false

  if [ ! -t 0 ]; then
    while true; do
      read -r reply
      [ -z "$reply" ] && reply="$default_choice"

      if [[ "$reply" =~ ^[0-9]+$ ]] && [ "$reply" -ge 1 ] && [ "$reply" -le "$max_choice" ]; then
        echo "$reply"
        return
      fi

      echo "Please choose a number from 1 to $max_choice." >&2
      exit 1
    done
  fi

  echo "Use Up/Down then Enter, or type a number." >&2
  echo "Press Ctrl+C to quit, or press Esc twice to cancel." >&2
  printf "Choose [%s]: " "$current" >&2

  while true; do
    if ! IFS= read -rsn1 key; then
      cancel_interactive
    fi

    case "$key" in
      "")
        printf "\n" >&2
        echo "$current"
        return
        ;;
      [1-9])
        if [ "$key" -le "$max_choice" ]; then
          printf "%s\n" "$key" >&2
          echo "$key"
          return
        fi
        printf "\r\033[KChoose [%s]: " "$current" >&2
        ;;
      $'\e')
        if IFS= read -rsn1 -t 1 next; then
          if [ "$next" = $'\e' ]; then
            cancel_interactive
          fi

          if [[ "$next" == "[" || "$next" == "O" ]]; then
            IFS= read -rsn1 -t 1 key || true
            case "$key" in
              A)
                if [ "$current" -le 1 ]; then
                  current="$max_choice"
                else
                  current=$((current - 1))
                fi
                ;;
              B)
                if [ "$current" -ge "$max_choice" ]; then
                  current=1
                else
                  current=$((current + 1))
                fi
                ;;
            esac
            esc_pending=false
            printf "\r\033[KChoose [%s]: " "$current" >&2
            continue
          fi
        fi

        if [ "$esc_pending" = true ]; then
          cancel_interactive
        fi

        esc_pending=true
        printf "\r\033[KPress Esc again to cancel, or choose [%s]: " "$current" >&2
        ;;
      *)
        esc_pending=false
        printf "\r\033[KChoose [%s]: " "$current" >&2
        ;;
    esac
  done
}

prompt_repo_dir() {
  local source_dir="$1"
  local repo_arg

  repo_arg=$(prompt_value "Source directory: " "$source_dir") || exit $?
  resolve_repo_dir "$repo_arg"
}

run_interactive_worktree_menu() {
  local source_dir
  local current_branch
  local default_branch
  local choice
  local dir_name
  local branch_name

  source_dir=$(resolve_repo_dir "")
  current_branch=$(get_current_branch "$source_dir")
  default_branch=$(get_default_branch "$source_dir")

  echo ""
  echo "Worktree setup"
  echo "  1) Ask each parameter"
  echo "  2) New worktree from current branch ($current_branch)"
  echo "  3) New worktree from default branch ($default_branch)"
  echo "  4) New worktree with custom branch off default branch"
  choice=$(prompt_menu_choice 1 4) || exit $?

  case "$choice" in
    1)
      dir_name=$(auto_worktree_name "$source_dir" "$default_branch")
      create_worktree "$dir_name" --dir "$source_dir" --interactive
      ;;
    2)
      source_dir=$(prompt_repo_dir "$source_dir") || exit $?
      current_branch=$(get_current_branch "$source_dir")
      dir_name=$(prompt_value "Worktree directory name: " "$(auto_worktree_name "$source_dir" "$current_branch")") || exit $?
      create_worktree "$dir_name" --dir "$source_dir" --src "$current_branch" --branch "$dir_name"
      ;;
    3)
      source_dir=$(prompt_repo_dir "$source_dir") || exit $?
      default_branch=$(get_default_branch "$source_dir")
      dir_name=$(prompt_value "Worktree directory name: " "$(auto_worktree_name "$source_dir" "$default_branch")") || exit $?
      create_worktree "$dir_name" --dir "$source_dir" --src "$default_branch" --branch "$dir_name"
      ;;
    4)
      source_dir=$(prompt_repo_dir "$source_dir") || exit $?
      default_branch=$(get_default_branch "$source_dir")
      dir_name=$(prompt_value "Worktree directory name: " "$(auto_worktree_name "$source_dir" "$default_branch")") || exit $?
      branch_name=$(prompt_value "Branch name: " "$dir_name") || exit $?
      create_worktree "$dir_name" --dir "$source_dir" --src "$default_branch" --branch "$branch_name"
      ;;
  esac
}

run_interactive_clone_menu() {
  local source_dir
  local current_branch
  local default_branch
  local choice
  local name
  local branch_name
  local manual_dir

  source_dir=$(resolve_repo_dir "")
  current_branch=$(get_current_branch "$source_dir")
  default_branch=$(get_default_branch "$source_dir")

  echo ""
  echo "Clone setup"
  echo "  1) Ask each parameter"
  echo "  2) New clone in parent directory from default branch ($default_branch)"
  echo "  3) New clone in parent directory from current branch ($current_branch)"
  echo "  4) New clone with custom branch off default branch"
  echo "  5) Apply setup to existing clone"
  choice=$(prompt_menu_choice 1 5) || exit $?

  case "$choice" in
    1)
      clone_repo --dir "$source_dir" --interactive
      ;;
    2)
      source_dir=$(prompt_repo_dir "$source_dir") || exit $?
      default_branch=$(get_default_branch "$source_dir")
      name=$(prompt_value "Clone folder name: " "$(auto_clone_name "$source_dir")") || exit $?
      clone_repo "$name" --dir "$source_dir" --src "$default_branch"
      ;;
    3)
      source_dir=$(prompt_repo_dir "$source_dir") || exit $?
      current_branch=$(get_current_branch "$source_dir")
      name=$(prompt_value "Clone folder name: " "$(auto_clone_name "$source_dir")") || exit $?
      clone_repo "$name" --dir "$source_dir" --src "$current_branch"
      ;;
    4)
      source_dir=$(prompt_repo_dir "$source_dir") || exit $?
      default_branch=$(get_default_branch "$source_dir")
      name=$(prompt_value "Clone folder name: " "$(auto_clone_name "$source_dir")") || exit $?
      branch_name=$(prompt_value "Branch name: " "$(sanitize_workspace_name "$name")") || exit $?
      clone_repo "$name" --dir "$source_dir" --src "$default_branch" --branch "$branch_name"
      ;;
    5)
      source_dir=$(prompt_repo_dir "$source_dir") || exit $?
      manual_dir=$(prompt_value "Existing clone directory: " "") || exit $?
      if [ -z "$manual_dir" ]; then
        echo "Error: Existing clone directory is required." >&2
        exit 1
      fi
      clone_repo --dir "$source_dir" --manual "$manual_dir"
      ;;
  esac
}

run_interactive_menu() {
  local choice

  trap cancel_interactive INT

  echo ""
  echo "wk interactive setup"
  echo "  1) Worktree"
  echo "  2) Clone"
  choice=$(prompt_menu_choice 1 2) || exit $?

  case "$choice" in
    1)
      run_interactive_worktree_menu
      ;;
    2)
      run_interactive_clone_menu
      ;;
  esac
}

# Copy files matching BOTH .worktreeinclude AND .gitignore
copy_worktree_files() {
  local source_dir="$1"
  local target_dir="$2"
  local include_file="$source_dir/.worktreeinclude"

  [ ! -f "$include_file" ] && return 0

  # Get all ignored files in source directory
  local ignored_files
  ignored_files=$(cd "$source_dir" && git ls-files --others --ignored --exclude-standard 2>/dev/null)

  [ -z "$ignored_files" ] && return 0

  # Read patterns from .worktreeinclude
  while IFS= read -r pattern || [ -n "$pattern" ]; do
    # Skip comments and empty lines
    [[ "$pattern" =~ ^[[:space:]]*# ]] && continue
    [[ -z "${pattern// }" ]] && continue
    pattern=$(echo "$pattern" | xargs)  # Trim whitespace

    # Match pattern against ignored files
    echo "$ignored_files" | while read -r file; do
      [ -z "$file" ] && continue

      local matched=false

      # Direct match or wildcard
      if [[ "$file" == $pattern ]]; then
        matched=true
      # Gitignore-style basename pattern (no slash matches at any depth)
      elif [[ "$pattern" != */* ]] && [[ "$(basename "$file")" == $pattern ]]; then
        matched=true
      # Directory pattern (pattern/)
      elif [[ "$pattern" == */ ]] && [[ "$file" == ${pattern}* ]]; then
        matched=true
      # Double-star pattern (**/file)
      elif [[ "$pattern" == \*\*/* ]]; then
        local suffix="${pattern#\*\*/}"
        if [[ "$file" == *"$suffix" ]] || [[ "$file" == "$suffix" ]]; then
          matched=true
        fi
      fi

      if [ "$matched" = true ]; then
        local src="$source_dir/$file"
        if [ -e "$src" ]; then
          mkdir -p "$target_dir/$(dirname "$file")"
          cp -r "$src" "$target_dir/$file"
          echo "  Copied: $file"
        fi
      fi
    done
  done < "$include_file"
}

# Run setup in target directory (Claude permissions + file copying)
run_setup() {
  local source_dir="$1"
  local target_dir="$2"

  # Create Claude Code settings
  mkdir -p "$target_dir/.claude"
  cat > "$target_dir/.claude/settings.local.json" << 'JSON_EOF'
{
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "WebFetch",
      "mcp__ide__getDiagnostics",
      "WebSearch",
      "mcp__github__pull_request_read",
      "mcp__github__search_pull_requests",
      "mcp__github__list_pull_requests"
    ],
    "deny": [],
    "ask": [
      "Bash(rm -rf:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)"
    ]
  }
}
JSON_EOF

  # Copy files matching .worktreeinclude
  copy_worktree_files "$source_dir" "$target_dir"
}

create_worktree() {
  local dir_name=""
  local repo_arg=""
  local source_dir=""
  local src_branch=""
  local branch_name=""
  local interactive=false

  # Parse arguments
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dir|-d)
        if [ $# -lt 2 ]; then
          echo "Error: $1 requires a directory." >&2
          echo "Usage: wk new <name> [--dir <source-dir>] [--src <source-branch>] [--branch <branch>]" >&2
          exit 1
        fi
        repo_arg="$2"
        shift 2
        ;;
      --src|-s)
        if [ $# -lt 2 ]; then
          echo "Error: $1 requires a source branch." >&2
          echo "Usage: wk new <name> [--dir <source-dir>] [--src <source-branch>] [--branch <branch>]" >&2
          exit 1
        fi
        src_branch="$2"
        shift 2
        ;;
      --branch|-b|--name|-n)
        if [ $# -lt 2 ]; then
          echo "Error: $1 requires a branch name." >&2
          echo "Usage: wk new <name> [--dir <source-dir>] [--src <source-branch>] [--branch <branch>]" >&2
          exit 1
        fi
        branch_name="$2"
        shift 2
        ;;
      --interactive|-i)
        interactive=true
        shift
        ;;
      --)
        shift
        break
        ;;
      -*)
        echo "Error: Unknown argument '$1'" >&2
        echo "Usage: wk new <name> [--dir <source-dir>] [--src <source-branch>] [--branch <branch>]" >&2
        exit 1
        ;;
      *)
        if [ -z "$dir_name" ]; then
          dir_name="$1"
        else
          echo "Error: Unknown argument '$1'" >&2
          echo "Usage: wk new <name> [--dir <source-dir>] [--src <source-branch>] [--branch <branch>]" >&2
          exit 1
        fi
        shift
        ;;
    esac
  done

  while [[ $# -gt 0 ]]; do
    if [ -z "$dir_name" ]; then
      dir_name="$1"
    else
      echo "Error: Unknown argument '$1'" >&2
      echo "Usage: wk new <name> [--dir <source-dir>] [--src <source-branch>] [--branch <branch>]" >&2
      exit 1
    fi
    shift
  done

  source_dir=$(resolve_repo_dir "$repo_arg")

  if [ "$interactive" = true ]; then
    trap cancel_interactive INT
    dir_name=$(prompt_value "Directory name: " "$dir_name") || exit $?
    repo_arg=$(prompt_value "Repository directory (--dir): " "$source_dir") || exit $?
    source_dir=$(resolve_repo_dir "$repo_arg")
    src_branch=$(prompt_value "Source branch (--src): " "${src_branch:-$(get_default_branch "$source_dir")}") || exit $?
    branch_name=$(prompt_value "Branch (--branch): " "${branch_name:-$dir_name}") || exit $?
  fi

  if [ -z "$dir_name" ]; then
    echo "Error: Directory name argument is required." >&2
    echo "Usage: wk new <name> [--dir <source-dir>] [--src <source-branch>] [--branch <branch>]" >&2
    exit 1
  fi

  if [ -z "$src_branch" ]; then
    src_branch=$(get_default_branch "$source_dir")
  fi

  if [ -z "$branch_name" ]; then
    branch_name="$dir_name"
  fi

  ensure_worktreeinclude "$source_dir"

  local target_path="$source_dir/.claude/worktrees/${dir_name}"

  if [ -e "$target_path" ]; then
    echo "Error: Directory '$target_path' already exists." >&2
    exit 1
  fi

  if git -C "$source_dir" show-ref --verify --quiet "refs/heads/$branch_name"; then
    echo "Creating worktree directory '$dir_name' at '$target_path' on existing branch '$branch_name'..."
    if ! git -C "$source_dir" worktree add "$target_path" "$branch_name"; then
      echo "Error: Worktree creation failed." >&2
      exit 1
    fi
  else
    echo "Creating worktree directory '$dir_name' at '$target_path' with branch '$branch_name' from '$src_branch'..."
    if ! git -C "$source_dir" worktree add "$target_path" -b "$branch_name" "$src_branch"; then
      echo "Error: Worktree creation failed." >&2
      exit 1
    fi
  fi

  echo "Running setup..."
  run_setup "$source_dir" "$target_path"
}

# Clone repo as sibling with setup
clone_repo() {
  local name=""
  local manual_dir=""
  local repo_arg=""
  local source_dir=""
  local src_branch=""
  local branch_name=""
  local interactive=false

  # Parse arguments
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --manual|-m)
        if [ $# -lt 2 ]; then
          echo "Error: $1 requires a directory." >&2
          echo "Usage: wk clone [<name>] [--dir <source-dir>] [--src <source-branch>] [--branch <branch>]" >&2
          exit 1
        fi
        manual_dir="$2"
        shift 2
        ;;
      --dir|-d)
        if [ $# -lt 2 ]; then
          echo "Error: $1 requires a directory." >&2
          echo "Usage: wk clone [<name>] [--dir <source-dir>] [--src <source-branch>] [--branch <branch>]" >&2
          exit 1
        fi
        repo_arg="$2"
        shift 2
        ;;
      --src|-s)
        if [ $# -lt 2 ]; then
          echo "Error: $1 requires a source branch." >&2
          echo "Usage: wk clone [<name>] [--dir <source-dir>] [--src <source-branch>] [--branch <branch>]" >&2
          exit 1
        fi
        src_branch="$2"
        shift 2
        ;;
      --branch|-b|--name|-n)
        if [ $# -lt 2 ]; then
          echo "Error: $1 requires a branch name." >&2
          echo "Usage: wk clone [<name>] [--dir <source-dir>] [--src <source-branch>] [--branch <branch>]" >&2
          exit 1
        fi
        branch_name="$2"
        shift 2
        ;;
      --interactive|-i)
        interactive=true
        shift
        ;;
      --)
        shift
        break
        ;;
      -*)
        echo "Error: Unknown argument '$1'" >&2
        echo "Usage: wk clone [<name>] [--dir <source-dir>] [--src <source-branch>] [--branch <branch>]" >&2
        exit 1
        ;;
      *)
        if [ -z "$name" ]; then
          name="$1"
        else
          echo "Error: Unknown argument '$1'" >&2
          echo "Usage: wk clone [<name>] [--dir <source-dir>] [--src <source-branch>] [--branch <branch>]" >&2
          exit 1
        fi
        shift
        ;;
    esac
  done

  while [[ $# -gt 0 ]]; do
    if [ -z "$name" ]; then
      name="$1"
    else
      echo "Error: Unknown argument '$1'" >&2
      echo "Usage: wk clone [<name>] [--dir <source-dir>] [--src <source-branch>] [--branch <branch>]" >&2
      exit 1
    fi
    shift
  done

  source_dir=$(resolve_repo_dir "$repo_arg")

  if [ "$interactive" = true ]; then
    trap cancel_interactive INT
    manual_dir=$(prompt_value "Existing clone directory (--manual, blank to create clone): " "$manual_dir") || exit $?
    repo_arg=$(prompt_value "Repository directory (--dir): " "$source_dir") || exit $?
    source_dir=$(resolve_repo_dir "$repo_arg")

    if [ -z "$manual_dir" ]; then
      name=$(prompt_value "Clone name: " "${name:-$(auto_clone_name "$source_dir")}") || exit $?
      src_branch=$(prompt_value "Source branch (--src): " "${src_branch:-$(get_default_branch "$source_dir")}") || exit $?
      branch_name=$(prompt_value "Branch (--branch): " "${branch_name:-$src_branch}") || exit $?
    fi
  fi

  # Manual mode: apply setup to existing clone
  if [ -n "$manual_dir" ]; then
    if [ -n "$src_branch" ] || [ -n "$branch_name" ]; then
      echo "Error: --src and --branch cannot be used with --manual." >&2
      exit 1
    fi

    # Resolve to absolute path
    if [[ ! "$manual_dir" = /* ]]; then
      manual_dir="$source_dir/$manual_dir"
    fi

    if [ ! -d "$manual_dir" ]; then
      echo "Error: Directory '$manual_dir' does not exist." >&2
      exit 1
    fi

    if [ ! -d "$manual_dir/.git" ] && [ ! -f "$manual_dir/.git" ]; then
      echo "Error: '$manual_dir' is not a git repository." >&2
      exit 1
    fi

    ensure_worktreeinclude "$source_dir"

    echo "Applying setup to $manual_dir..."
    run_setup "$source_dir" "$manual_dir"
    echo "Done"
    return
  fi

  # Clone mode: create new sibling clone
  local remote_url
  remote_url=$(git -C "$source_dir" remote get-url origin 2>/dev/null)

  if [ -z "$remote_url" ]; then
    echo "Error: No remote 'origin' found." >&2
    exit 1
  fi

  if [ -z "$src_branch" ]; then
    src_branch=$(get_default_branch "$source_dir")
  fi

  if [ -z "$branch_name" ]; then
    branch_name="$src_branch"
  fi

  # Auto-name if no name given
  if [ -z "$name" ]; then
    name=$(auto_clone_name "$source_dir")
  fi

  local target_path
  target_path="$(dirname "$source_dir")/$name"

  if [ -d "$target_path" ]; then
    echo "Error: Directory '$target_path' already exists." >&2
    exit 1
  fi

  ensure_worktreeinclude "$source_dir"

  echo "Cloning '$src_branch' to '$target_path'..."
  if ! git clone --branch "$src_branch" "$remote_url" "$target_path"; then
    echo "Error: Clone failed." >&2
    exit 1
  fi

  if [ "$branch_name" != "$src_branch" ]; then
    echo "Creating branch '$branch_name' from '$src_branch'..."
    if git -C "$target_path" show-ref --verify --quiet "refs/heads/$branch_name"; then
      if ! git -C "$target_path" checkout "$branch_name"; then
        echo "Error: Branch checkout failed." >&2
        exit 1
      fi
    else
      if ! git -C "$target_path" checkout -b "$branch_name"; then
        echo "Error: Branch creation failed." >&2
        exit 1
      fi
    fi
  fi

  echo "Running setup..."
  local abs_target
  abs_target=$(cd "$target_path" && pwd)
  run_setup "$source_dir" "$abs_target"
  echo "Done"
}

# Navigate to a worktree by branch name
go_to_worktree() {
  local name="$1"
  if [ -z "$name" ]; then
    echo "Error: Branch name or index required." >&2
    echo "Usage: wk go <branch-name|index>" >&2
    exit 1
  fi

  if [[ "$name" =~ ^[0-9]+$ ]]; then
    local index_path
    if index_path=$(get_path_for_index "$name"); then
      print_navigation_target "$index_path"
      return
    fi
  fi

  # Find worktree path by branch name
  local path=$(git worktree list --porcelain 2>/dev/null | awk -v branch="$name" '
    /^worktree / { wt = substr($0, 10) }
    /^branch / { if ($0 ~ branch "$") print wt }
  ')

  if [ -z "$path" ]; then
    echo "Error: No worktree found for branch '$name'" >&2
    exit 1
  fi

  # Output path for shell function to cd
  print_navigation_target "$path"
}

# Navigate back to main worktree
go_back() {
  local main_path=$(git worktree list --porcelain 2>/dev/null | awk '
    /^worktree / { wt = substr($0, 10) }
    /^bare$/ { next }
    /^HEAD / { if (wt) { print wt; exit } }
  ')

  if [ -z "$main_path" ]; then
    # Fallback: first worktree
    main_path=$(git worktree list 2>/dev/null | head -1 | awk '{print $1}')
  fi

  if [ -z "$main_path" ]; then
    echo "Error: Could not find main worktree" >&2
    exit 1
  fi

  print_navigation_target "$main_path"
}

# Collect all entries (worktrees + sibling clones, deduplicated)
# Output: path|type lines
collect_entries() {
  local main_path
  main_path=$(git worktree list 2>/dev/null | head -1 | awk '{print $1}')
  [ -z "$main_path" ] && main_path=$(pwd)

  local parent_dir base_name
  parent_dir=$(dirname "$main_path")
  base_name=$(basename "$main_path" | sed -E 's/[-.]?[0-9]+$//' | sed -E 's/\.[^.]+$//')

  # Find all sibling repos sharing the base name
  local siblings=()
  while IFS= read -r dir; do
    if [[ -d "$dir/.git" || -f "$dir/.git" ]]; then
      siblings+=("$dir")
    fi
  done < <(find "$parent_dir" -maxdepth 1 -type d -name "${base_name}*" 2>/dev/null | sort)

  # Fallback: no siblings found, list current repo's worktrees
  if [[ ${#siblings[@]} -eq 0 ]]; then
    git worktree list 2>/dev/null | while IFS= read -r line; do
      echo "$(echo "$line" | awk '{print $1}')|worktree"
    done
    return
  fi

  # For each sibling, list its worktrees or mark as clone
  for dir in "${siblings[@]}"; do
    local wt_count
    wt_count=$(git -C "$dir" worktree list 2>/dev/null | wc -l | tr -d ' ')

    if [[ "$wt_count" -gt 1 ]]; then
      git -C "$dir" worktree list 2>/dev/null | while IFS= read -r wt_line; do
        echo "$(echo "$wt_line" | awk '{print $1}')|worktree"
      done
    else
      if [[ ${#siblings[@]} -gt 1 ]]; then
        echo "$dir|clone"
      else
        echo "$dir|worktree"
      fi
    fi
  done | awk -F'|' '!seen[$1]++'
}

get_path_for_index() {
  local requested="$1"

  if [[ ! "$requested" =~ ^[0-9]+$ ]]; then
    return 2
  fi

  local index=$((10#$requested))

  local entries=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && entries+=("${line%|*}")
  done < <(collect_entries)

  if [[ $index -ge ${#entries[@]} ]]; then
    return 1
  fi

  echo "${entries[$index]}"
}

# Navigate to worktree/clone by index
go_to_index() {
  local requested="$1"
  local path

  if ! path=$(get_path_for_index "$requested"); then
    if [[ ! "$requested" =~ ^[0-9]+$ ]]; then
      echo "Error: Invalid index '$requested'" >&2
      exit 1
    fi

    echo "Error: No entry at index $requested" >&2
    echo "" >&2
    echo "Available:" >&2
    list_indexed >&2
    exit 1
  fi

  print_navigation_target "$path"
}

# List all worktrees and clones with aligned columns
list_indexed() {
  local current_dir
  current_dir=$(pwd -P)

  local paths=() types=()
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    paths+=("${line%|*}")
    types+=("${line##*|}")
  done < <(collect_entries)

  # Find max path length for column alignment
  local max_len=0
  for p in "${paths[@]}"; do
    [[ ${#p} -gt $max_len ]] && max_len=${#p}
  done

  # Find max type length for alignment
  local max_type=0
  for t in "${types[@]}"; do
    local label="[$t]"
    [[ ${#label} -gt $max_type ]] && max_type=${#label}
  done

  for i in "${!paths[@]}"; do
    local path="${paths[$i]}"
    local type="${types[$i]}"
    local label="[$type]"
    local resolved
    resolved=$(cd "$path" 2>/dev/null && pwd -P)
    local marker=""
    [[ "$resolved" == "$current_dir" ]] && marker=" *"
    printf "%d  %-${max_len}s  %-${max_type}s%s\n" "$i" "$path" "$label" "$marker"
  done
}

# Edit .worktreeinclude config file
edit_config() {
  ensure_worktreeinclude

  local configfile=".worktreeinclude"
  local editor="${EDITOR:-${VISUAL:-}}"

  if [ -n "$editor" ]; then
    $editor "$configfile"
  else
    echo "No default text editor configured."
    echo ""
    echo "To set one, add to your shell config (~/.zshrc or ~/.bashrc):"
    echo "  export EDITOR=nano      # or vim, subl, code, etc."
    echo ""
    read -p "Open with VSCode instead? [y/N] " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
      code "$configfile"
    fi
  fi
}

case "$1" in
  go)
    go_to_worktree "$2"
    ;;
  back|b)
    go_back
    ;;
  list|ls|l)
    list_indexed
    ;;
  config)
    edit_config
    ;;
  clone|c)
    shift
    clone_repo "$@"
    ;;
  new|n)
    shift
    create_worktree "$@"
    ;;
  -i|--interactive)
    run_interactive_menu
    ;;
  -h|--help)
    show_help
    ;;
  "")
    if [ -t 0 ]; then
      run_interactive_menu
    else
      show_help
    fi
    ;;
  -v|--version|version)
    echo "wk $VERSION"
    ;;
  *)
    if [[ "${1:-}" =~ ^[0-9]+$ ]]; then
      go_to_index "$1"
      exit $?
    fi
    echo "Error: Unknown command '$1'"
    echo ""
    show_help
    exit 1
    ;;
esac
